# Copy to .env.production and set real production values before running compose.

BACKEND_PORT=4000
FRONTEND_PORT=8080

API_KEY=
WEBHOOK_SECRET=
PAYMENT_INTENT_SECRET=
SIWE_JWT_SECRET=

QIE_RPC_URL=https://rpc1mainnet.qie.digital
QIE_TESTNET_RPC_URL=https://rpc1testnet.qie.digital
QIE_EXPLORER_URL=https://mainnet.qie.digital
QIE_TESTNET_EXPLORER_URL=https://testnet.qie.digital
QIE_TESTNET_FAUCET_URL=https://www.qie.digital/faucet
QIE_WALLET_URL=https://qiewallet.me
QIE_DOMAINS_URL=https://domains.qie.digital
QIE_PASS_URL=https://qiepass.qie.digital
QIE_PASS_VERIFICATION_URL=
QIE_DEX_URL=https://www.dex.qie.digital
QIE_BRIDGE_URL=https://bridge.qie.digital
QIE_DOCS_URL=https://docs.qie.digital
QUSDC_STABLE_URL=https://www.stable.qie.digital
QANTARA_ADDRESS=0x27815fC2021345EB38B68D9C8F08679A4aeee030
QANTARA_MULTIPAY_ADDRESS=0x72a5B88063E5783954c64244b75f9F8fDb3751Bb
# Replace before production QUSDC enablement. This example address currently
# returns a non-production token label on QIE RPC, so production-preflight fails it.
QUSDC_ADDRESS=0x88aBC76fd8e3d725139Ecc6BB75582aA3f14ec2D
# Optional QUSDC vault acquisition route. Leave empty unless real QIE mainnet
# vault/WUSDC contracts are configured; Qantara never marks invoices paid here.
QUSDC_VAULT_ADDRESS=
WUSDC_ADDRESS=
QUSDC_VAULT_MINT_METHOD=mint
MILESTONE_ESCROW_ADDRESS=0x1D096D48d7bb2E6eF2FAfD1eC13C867b5461BA98
RECURRING_SCHEDULER_ADDRESS=0xb05D67901A43644fD831EEC4e6554970e791F690
BATCH_PAYOUT_ADDRESS=0x49EC10ACd67716e35E5129c9ae83C62456502a83
QANTARA_CHAT_ADDRESS=0x76E618ecca8D97038Ec11641E16b9e16a378576A
QANTARA_SPLITS_ADDRESS=0xBbaeF9CF47C31436505E46cF2a39636a76C7C413
QANTARA_SUBSCRIPTION_V2_ADDRESS=0x30ACe939BD62b6a9E9aF3f5AB4287b5FB5F39c06
QANTARA_GAS_RELAY_ADDRESS=0xE027abFb3F845c6798fA247f1053Bd1B143768d2
# V4 gas relay (gasless payments). The relayer is a SEPARATE hot wallet that
# sponsors gas via QantaraGasRelay — fund it with a little QIE. Never reuse a
# merchant wallet, and never expose RELAYER_PK to the browser build. Without
# RELAYER_PK the gasless /v1/relay/sponsor route stays disabled.
RELAYER_PK=
RELAYER_MAX_TX_PER_ADDR_PER_DAY=20
RELAYER_MAX_VALUE_PER_TX_QIE=0.1
# Optional gasless stablecoin checkout rail. Leave empty unless a real HTTPS
# paymaster checkout is live; Qantara will otherwise keep this route disabled.
QUSDC_PAYMASTER_CHECKOUT_URL=
QUSDC_PAYMASTER_PROVIDER=qie_paymaster
# Optional receipt anchor registry (QantaraReceiptRegistry). Leave empty unless a
# real registry is deployed. Anchoring only mirrors backend-issued receipt hashes
# on-chain for auditability; it never affects paid/refunded state.
QANTARA_RECEIPT_REGISTRY_ADDRESS=
# Signer for on-chain receipt anchoring. Falls back to RELAYER_PK when empty.
# Must be an allowed issuer on the registry and funded with a little QIE for gas.
# Without a registry address AND a signer, anchoring stays disabled (receipts are
# still issued; the /v1/receipts/:hash/anchor route returns 412).
RECEIPT_ANCHOR_PK=
# Set to true to auto-anchor newly issued receipts in the background worker.
# Default (empty) anchors only on demand via the API. Tune the worker cadence
# with RECEIPT_ANCHOR_INTERVAL_MS (min 15000).
RECEIPT_ANCHOR_AUTO=
RECEIPT_ANCHOR_INTERVAL_MS=60000

QANTARA_FRONTEND_URL=https://qantara.app
CORS_ORIGINS=https://qantara.app

CHAIN_INDEXER_INTERVAL_MS=15000
WEBHOOK_RETRY_INTERVAL_MS=15000
INDEXER_MAX_LAG_BLOCKS=50
INDEXER_STALE_AFTER_SECONDS=120
WEBHOOK_MAX_DUE_RETRIES=0
RPC_VERIFY_MAX_FAILURES_24H=0
# Re-org safety: index this many blocks behind the chain head (0 = index to head).
CHAIN_CONFIRMATIONS=5
# Hard cap (seconds) on how long a single failing webhook is retried before terminal.
WEBHOOK_MAX_RETRY_WINDOW_SECONDS=86400

# Observability and abuse protection.
LOG_LEVEL=info
RATE_LIMIT_CHECKOUT_PER_MIN=120
RATE_LIMIT_INVOICES_PER_MIN=240
RATE_LIMIT_AUTH_PER_MIN=60

ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
ALERT_MIN_SEVERITY=critical
ALERT_COOLDOWN_SECONDS=300
ALERT_INTERVAL_MS=60000

# Optional AI checkout copilot. Leave ANTHROPIC_API_KEY empty to disable.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
COPILOT_RATE_LIMIT_PER_MIN=10
COPILOT_MAX_TOKENS_OUTPUT=1000

BOT_TOKEN=
QANTARA_BACKEND_URL=https://api.qantara.app
QANTARA_BASE_URL=https://qantara.app
QANTARA_API_KEY=
DEFAULT_TOKEN=QIE
BOT_WEBHOOK_URL=
BOT_WEBHOOK_PORT=8081
BOT_WEBHOOK_MAX_BODY_BYTES=262144
ALERT_CHAT_ID=

VITE_QANTARA_BACKEND_URL=https://api.qantara.app
VITE_QANTARA_ADDRESS=0x27815fC2021345EB38B68D9C8F08679A4aeee030
VITE_QANTARA_MULTIPAY_ADDRESS=0x72a5B88063E5783954c64244b75f9F8fDb3751Bb
# Must match QUSDC_ADDRESS after a real production token is configured.
VITE_QUSDC_ADDRESS=0x88aBC76fd8e3d725139Ecc6BB75582aA3f14ec2D
VITE_MILESTONE_ESCROW_ADDRESS=0x1D096D48d7bb2E6eF2FAfD1eC13C867b5461BA98
VITE_RECURRING_SCHEDULER_ADDRESS=0xb05D67901A43644fD831EEC4e6554970e791F690
VITE_BATCH_PAYOUT_ADDRESS=0x49EC10ACd67716e35E5129c9ae83C62456502a83
VITE_QANTARA_SUPPORTS_EIP3009=false
VITE_QUSDC_EIP3009_VERSION=1
VITE_QANTARA_CHAT_ADDRESS=0x76E618ecca8D97038Ec11641E16b9e16a378576A
VITE_QANTARA_SPLITS_ADDRESS=0xBbaeF9CF47C31436505E46cF2a39636a76C7C413
VITE_QANTARA_SUBSCRIPTION_V2_ADDRESS=0x30ACe939BD62b6a9E9aF3f5AB4287b5FB5F39c06
VITE_QANTARA_GAS_RELAY_ADDRESS=0xE027abFb3F845c6798fA247f1053Bd1B143768d2

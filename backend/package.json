{
  "name": "qantara-backend",
  "version": "1.0.0-rc.1",
  "description": "Backend API for Qantara - hosted checkout sessions, receipts, alerts, and HMAC webhooks.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "jose": "^5.10.0",
    "siwe": "^2.3.2",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}

# Copy to .env

# Server
PORT=4000
NODE_ENV=production

# Frontend URL (used in checkout session response: { url: QANTARA_FRONTEND_URL/checkout/:hash })
QANTARA_FRONTEND_URL=https://qantara.app

# Operator API key. Store per-merchant keys in the database for merchant access.
# Generated with: openssl rand -hex 32
API_KEY=

# Webhook signing secret (per-merchant in production)
# Generated with: openssl rand -hex 32
WEBHOOK_SECRET=

# Optional operational alert webhook.
# Payloads are HMAC-signed with ALERT_WEBHOOK_SECRET.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
ALERT_MIN_SEVERITY=critical
ALERT_COOLDOWN_SECONDS=300
ALERT_INTERVAL_MS=60000

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://qantara.app

# QIE network and ecosystem catalog. Custom RPC URLs are used by the backend,
# but public status responses redact credentials/query strings.
QIE_RPC_URL=https://rpc1mainnet.qie.digital
QIE_TESTNET_RPC_URL=https://rpc1testnet.qie.digital
QIE_EXPLORER_URL=https://mainnet.qie.digital
QIE_TESTNET_EXPLORER_URL=https://testnet.qie.digital
QIE_TESTNET_FAUCET_URL=https://www.qie.digital/faucet
QIE_WALLET_URL=https://qiewallet.me
QIE_DOMAINS_URL=https://domains.qie.digital
QIE_PASS_URL=https://qiepass.qie.digital
QIE_PASS_VERIFICATION_URL=
QIE_DEX_URL=https://www.dex.qie.digital
QIE_BRIDGE_URL=https://bridge.qie.digital
QIE_DOCS_URL=https://docs.qie.digital
QUSDC_STABLE_URL=https://www.stable.qie.digital

# Optional QUSDC vault acquisition route. Leave disabled unless these are real
# QIE mainnet contracts; invoice paid-state still requires /verify-payment.
QUSDC_ADDRESS=
QUSDC_VAULT_ADDRESS=
WUSDC_ADDRESS=
QUSDC_VAULT_MINT_METHOD=mint

# ============ V4 ============
# Relayer wallet (separate from merchant!) — sponsors gas via QantaraGasRelay
RELAYER_PK=
RELAYER_MAX_TX_PER_ADDR_PER_DAY=20
RELAYER_MAX_VALUE_PER_TX_QIE=0.1
QANTARA_GAS_RELAY_ADDRESS=0xE027abFb3F845c6798fA247f1053Bd1B143768d2

# Optional receipt registry address. Leave empty unless a real on-chain registry is deployed and indexed.
QANTARA_RECEIPT_REGISTRY_ADDRESS=

# AI checkout copilot (Anthropic recommended — cheaper, OpenAI fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
COPILOT_RATE_LIMIT_PER_MIN=10
COPILOT_MAX_TOKENS_OUTPUT=1000

# SIWE session signing — generate with: openssl rand -hex 32
SIWE_JWT_SECRET=
SIWE_SESSION_TTL_HOURS=24

# Fiat onramp webhooks (set after Moonpay/Transak partner approval)
MOONPAY_WEBHOOK_SECRET=
TRANSAK_WEBHOOK_SECRET=

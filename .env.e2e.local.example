E2E_BACKEND_URL=http://127.0.0.1:4000
E2E_FRONTEND_URL=http://127.0.0.1:5173
E2E_QIE_RPC_URL=https://rpc1testnet.qie.digital
E2E_CHAIN_ID=1983
E2E_CHAIN_NAME=QIE Testnet
E2E_EXPLORER_URL=https://testnet.qie.digital

# Required for wallet/on-chain Playwright lanes.
# Use low-balance dedicated wallets only.
E2E_MERCHANT_PRIVATE_KEY=0x
E2E_PAYER_PRIVATE_KEY=0x
E2E_ALLOW_REAL_TX=false
# Backward-compatible legacy alias. Prefer E2E_ALLOW_REAL_TX for testnet.
E2E_ALLOW_MAINNET_TX=false
E2E_MAX_SPEND_QIE=0.05
E2E_INVOICE_AMOUNT_QIE=0.001

# Optional QUSDC validation lane.
E2E_QUSDC_ADDRESS=
E2E_QUSDC_AMOUNT=0.01

# Optional webhook receiver used by staging smoke scripts.
E2E_WEBHOOK_RECEIVER_URL=

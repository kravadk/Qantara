# syntax=docker/dockerfile:1.7

FROM node:24-alpine AS build
WORKDIR /app

COPY package.json package-lock.json* .npmrc* ./
RUN npm ci

COPY index.html vite.config.ts tsconfig.json ./
COPY public ./public
COPY src ./src

ARG VITE_QANTARA_BACKEND_URL
ARG VITE_QANTARA_ADDRESS
ARG VITE_QANTARA_MULTIPAY_ADDRESS
ARG VITE_QUSDC_ADDRESS
ARG VITE_MILESTONE_ESCROW_ADDRESS
ARG VITE_RECURRING_SCHEDULER_ADDRESS
ARG VITE_BATCH_PAYOUT_ADDRESS
ARG VITE_QANTARA_SUPPORTS_EIP3009=false
ARG VITE_QUSDC_EIP3009_VERSION=1
ARG VITE_QANTARA_CHAT_ADDRESS
ARG VITE_QANTARA_SPLITS_ADDRESS
ARG VITE_QANTARA_SUBSCRIPTION_V2_ADDRESS
ARG VITE_QANTARA_GAS_RELAY_ADDRESS

ENV VITE_QANTARA_BACKEND_URL=$VITE_QANTARA_BACKEND_URL
ENV VITE_QANTARA_ADDRESS=$VITE_QANTARA_ADDRESS
ENV VITE_QANTARA_MULTIPAY_ADDRESS=$VITE_QANTARA_MULTIPAY_ADDRESS
ENV VITE_QUSDC_ADDRESS=$VITE_QUSDC_ADDRESS
ENV VITE_MILESTONE_ESCROW_ADDRESS=$VITE_MILESTONE_ESCROW_ADDRESS
ENV VITE_RECURRING_SCHEDULER_ADDRESS=$VITE_RECURRING_SCHEDULER_ADDRESS
ENV VITE_BATCH_PAYOUT_ADDRESS=$VITE_BATCH_PAYOUT_ADDRESS
ENV VITE_QANTARA_SUPPORTS_EIP3009=$VITE_QANTARA_SUPPORTS_EIP3009
ENV VITE_QUSDC_EIP3009_VERSION=$VITE_QUSDC_EIP3009_VERSION
ENV VITE_QANTARA_CHAT_ADDRESS=$VITE_QANTARA_CHAT_ADDRESS
ENV VITE_QANTARA_SPLITS_ADDRESS=$VITE_QANTARA_SPLITS_ADDRESS
ENV VITE_QANTARA_SUBSCRIPTION_V2_ADDRESS=$VITE_QANTARA_SUBSCRIPTION_V2_ADDRESS
ENV VITE_QANTARA_GAS_RELAY_ADDRESS=$VITE_QANTARA_GAS_RELAY_ADDRESS

RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
RUN sed -i -e 's#pid[[:space:]].*#pid /tmp/nginx.pid;#' -e 's#^user[[:space:]].*##' /etc/nginx/nginx.conf \
  && mkdir -p /var/cache/nginx /var/run /var/log/nginx \
  && chown -R nginx:nginx /var/cache/nginx /var/run /var/log/nginx /usr/share/nginx/html

EXPOSE 8080

USER nginx
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD wget -q -O /dev/null http://127.0.0.1:8080/ || exit 1

ENTRYPOINT ["nginx"]
CMD ["-g", "daemon off;"]

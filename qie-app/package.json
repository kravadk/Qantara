{
  "name": "qantara",
  "private": true,
  "version": "1.0.0-rc.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port=5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run src",
    "test:coverage": "vitest run src --coverage",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --project=chromium",
    "e2e:preflight": "node scripts/e2e-preflight.mjs",
    "e2e:real": "node scripts/e2e-preflight.mjs && playwright test --project=chromium e2e/public-navigation.spec.ts e2e/wallet-flow.spec.ts e2e/real-payment.spec.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.91.2",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.3.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "viem": "^2.47.5",
    "wagmi": "^2.13.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "agentation": "^3.0.2",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.7"
  }
}

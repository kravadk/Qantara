# Qantara — frontend env

# Backend REST API
VITE_QANTARA_BACKEND_URL=https://api.qantara.app

# Deployed contract addresses on QIE Mainnet (chain 1990).
# Populate after running `cd contracts && npm run deploy:qie` — the deploy script prints them.
VITE_QANTARA_ADDRESS=0x27815fC2021345EB38B68D9C8F08679A4aeee030
VITE_QANTARA_MULTIPAY_ADDRESS=0x72a5B88063E5783954c64244b75f9F8fDb3751Bb
VITE_QUSDC_ADDRESS=0x88aBC76fd8e3d725139Ecc6BB75582aA3f14ec2D
VITE_QANTARA_SUPPORTS_EIP3009=false
VITE_QUSDC_EIP3009_VERSION=1

# ============ V4 contracts (live since 2026-05-28) ============
VITE_QANTARA_CHAT_ADDRESS=0x76E618ecca8D97038Ec11641E16b9e16a378576A
VITE_QANTARA_SPLITS_ADDRESS=0xBbaeF9CF47C31436505E46cF2a39636a76C7C413
VITE_QANTARA_SUBSCRIPTION_V2_ADDRESS=0x30ACe939BD62b6a9E9aF3f5AB4287b5FB5F39c06
VITE_QANTARA_GAS_RELAY_ADDRESS=0xE027abFb3F845c6798fA247f1053Bd1B143768d2
# ERC-2771 gasless chat target consumed by the gas relay. Without it the chat
# panel falls back to self-paid on-chain messages.
VITE_QANTARA_CHAT2771_ADDRESS=0xE403F19b533A3fe198835C872Cc11a11cd4bdA75
# InstallmentPlan (pay-over-time / BNPL) — live on QIE Mainnet.
VITE_INSTALLMENT_PLAN_ADDRESS=0x9F42070de1C7F545949A6259D22bBf253A34c374

# ============ V4 fiat onramp ============
# Card checkout must be created through a backend provider session.
# Do not place provider credentials or checkout launch parameters in browser env.
